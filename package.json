{
  "name": "honey",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local CLI harness for learning Codex or Claude Code style runtime design.",
  "bin": {
    "honey": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "docs/assets/honey-banner.svg"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-skill-assets.mjs && node ./scripts/clean-dist.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "eval": "node --enable-source-maps dist/evals/runEval.js",
    "start": "node --enable-source-maps dist/cli.js",
    "start:deepseek": "node --enable-source-maps dist/cli.js --provider deepseek --dump-prompts",
    "demo": "node --enable-source-maps dist/cli.js \"read: CONTEXT.md\""
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.31",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "ink": "^5.2.1",
    "react": "^18.3.1"
  }
}
